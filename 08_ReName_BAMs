"8.2_ReHeaderBAM.sh"
#################################################################################################################################
#!/bin/bash
#SBATCH -J ReHeaderBAM
#SBATCH -o /scratch/project_2009316/EuSamples/05.BAM/logs/ReHeaderBAM_%j.out
#SBATCH -e /scratch/project_2009316/EuSamples/05.BAM/logs/ReHeaderBAM_%j.err
#SBATCH --account=project_2009316
#SBATCH -t 04:00:00
#SBATCH -p small
#SBATCH --array=301-385  #385 ##change to number of samples
#SBATCH --ntasks 4
#SBATCH --mem-per-cpu=8GB
#SBATCH --mail-type=BEGIN,END,FAIL

set -euo pipefail
module load biokit

# Rename BAM files and update their @RG SM/ID tags in the header
# Usage: bash rename_bam_headers.sh
# Requires: samtools

#BAM_DIR="/scratch/project_2009316/EuSamples/05.BAM/nodupl_clip"     # directory containing BAM files
BAM_LIST=/scratch/project_2009316/EuSamples/05.BAM/nodupl_clip/all.bam.list
OUT_DIR="/scratch/project_2009316/EuSamples/05.BAM/BAM_final"

mkdir -p "$OUT_DIR"

# Pick BAM for this array index
bam=$(sed -n "${SLURM_ARRAY_TASK_ID}p" "$BAM_LIST")
base=$(basename "$bam" .bam)
out="$OUT_DIR/${base}.rgfixed.bam"

echo "[$(date)] Task $SLURM_ARRAY_TASK_ID processing: $bam"
echo "Output: $out"

CPUS=${SLURM_CPUS_PER_TASK:-4}

samtools addreplacerg \
  -r "ID:${base}\tSM:${base}\tPL:ILLUMINA\tLB:1\tPU:1" \
  -@ "$CPUS" \
  -o "$out" \
  "$bam"

samtools index "$out"

echo "[$(date)] Done: $out"
#################################################################################################################################

Now, data can be used for SNP calling
