# Until now, we have filtered the VCF file. So first (10.4_BCFfiltering.sh), we do per‑individual depth filtering based on sample‑specific max DP,
# and constant min DP. So for each individual, we create a VCF for which the genotypes are set to ".",
# where DP is outside [dpmin, dpmax) and index them
# Second (10.5_BCFfiltering.sh), we merge newly DP‑filtered VCF files into a single file, then do further HWE testing and HWE filtering.
# Lastly (10.6_BCFfiltering.sh), we delete old files
# Then, we continue with further filtering on minimum depth per sample and based on missing data (10_VCF_filtering_7-XX).

vim "10.4_BCFfiltering_IndDepth.sh"
#per‑individual depth filtering based on sample‑specific max DP, and constant min DP.
#################################################################################################################################
#!/bin/bash -l
#SBATCH -J splitDP
#SBATCH --account=project_2009316
#SBATCH -o /scratch/project_2009316/EuSamples/06.VCF/logs/splitDP_%a.out
#SBATCH -e /scratch/project_2009316/EuSamples/06.VCF/logs/splitDP_%a.err
#SBATCH -t 24:00:00
#SBATCH -p small
#SBATCH --array=38-75       # <-- 385 last -  adjust to number of lines in ind.list
#SBATCH --ntasks=1
#SBATCH --mem=12G
#SBATCH --mail-type=BEGIN,END,FAIL

set -euo pipefail

module load biokit
#export PATH="/projappl/project_2009316/myenv/bin:$PATH"

BASE=/scratch/project_2009316/EuSamples
VCFDIR="$BASE/06.VCF"
FILT="$VCFDIR/filt"

cd "$FILT"

BASENAME="all_samples.norm.dec.sor.nopha.SNPQ30.biall.fixedHeader"
FIXED_VCF="${BASENAME}.vcf.gz"
DP_THRESH="${BASENAME}.idepth.MinMax"

# Get individual ID from ind.list
ind=$(sed -n "${SLURM_ARRAY_TASK_ID}p" ind.list)

#cd /scratch/project_2009316/EuSamples/06.VCF/filt
mkdir -p "individualDP/${ind}"
cd "individualDP/${ind}"

# Hard-coded min DP; max is sample-specific from DP_THRESH
dpmin=2
dpmax=$(grep -w "$ind" "$FILT/$DP_THRESH" | cut -f5)

echo "Processing individual $ind with $dpmin < DP <= $dpmax"

bcftools view \
  -s "$ind" \
  -Ou "$FILT/$FIXED_VCF" \
  | bcftools filter \
      -e "FORMAT/DP < ${dpmin} | FORMAT/DP >= ${dpmax}" \
      --set-GTs . \
      -Oz \
      -o "${ind}.vcf.gz"

bcftools index -t "${ind}.vcf.gz"

#END


