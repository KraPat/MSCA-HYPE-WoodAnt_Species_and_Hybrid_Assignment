# 3.4. Remove sites with heterozygote excess from VCF
vcftools \
  --gzvcf all_samples.SNPQ30.biall.fixedHeader.indDP.vcf.gz \
  --exclude-bed nohwe_excess_SAMPLES_hwe.bed \
  --recode \
  --recode-INFO-all \
  --stdout \
  | bgzip > all_samples.SNPQ30.biall.fixedHeader.indDP.hwe.vcf.gz

bcftools index -t all_samples.SNPQ30.biall.fixedHeader.indDP.hwe.vcf.gz

