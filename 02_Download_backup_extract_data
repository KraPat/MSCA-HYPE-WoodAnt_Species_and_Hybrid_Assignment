## First, we create a screen, download the data using the URL and wget, 
screen
module load sratoolkit 
## 1. Define your links in a space-separated list
LINKS="https://sra-pub-run-odp.s3.amazonaws.com/sra/SRR15845271/SRR15845271
https://sra-pub-run-odp.s3.amazonaws.com/sra/SRR15845547/SRR15845547
https://sra-pub-run-odp.s3.amazonaws.com/sra/SRR15278649/SRR15278649
https://sra-pub-run-odp.s3.amazonaws.com/sra/SRR12432375/SRR12432375 
https://sra-pub-run-odp.s3.amazonaws.com/sra/SRR15845271/SRR15845271"

# 2. Start the loop
for URL in $LINKS; do # Extract the filename from the URL (the last part after the '/')
FILENAME=$(basename $URL)

echo "Starting download for $FILENAME..." 
# Download the file and ensure it is saved as the Accession name
wget -O "$FILENAME.sra" "$URL"

echo "Extracting $FILENAME..." 
# Run fasterq-dump on the newly downloaded file
fasterq-dump "$FILENAME.sra" --threads 4 --progress

# Optional: Remove the .sra file to save space after extraction
# rm "$FILENAME.sra"

done
