## First, we need to get all files needed to analyse the data. These consist of multiple WGS events stored on the Finnish ALLAS long-term storage. 
## After retrieving all files, we store the ones that need to be index in the "bam_final" folder and run the script detailed below to index the samples. 
## Before running the script, we need to create the input.list by running
ls *.bam > input.list
## Note, in total there are 259 samples now. However, there will be more samples, which are stored in another folder and already have an index .bai file. 
## The script is called 9.1_Index.sh

#################################################################################################################################
#!/bin/bash -l
#SBATCH -J indexSamples
#SBATCH -o /scratch/project_2009316/EuSamples/05.BAM/logs/indexBam_%j.out
#SBATCH -e /scratch/project_2009316/EuSamples/05.BAM/logs/indexBam_%j.err
#SBATCH --account=project_2009316
#SBATCH -t 04:00:00
#SBATCH -p small
#SBATCH --array=1-2 ##change to number of samples
#SBATCH --ntasks 1
#SBATCH --mem-per-cpu=4GB
#SBATCH --mail-type=BEGIN,END,FAIL

# Load modules
module load biokit

# Define directories
cd /scratch/project_2009316/EuSamples/05.BAM/bam_final
INPUTDIR=/scratch/project_2009316/EuSamples/05.BAM/bam_final
FINALDIR=/scratch/project_2009316/EuSamples/05.BAM/bam_final

# Get file & sample ID
file=$(sed -n "$SLURM_ARRAY_TASK_ID"p input.list)
sample=${file%_nodupl*}

echo "### Processing $file"

###
### Index
###

samtools index "$FINALDIR/${sample}_nodupl_wRG_clip.bam"

### END OF THE SCRIPT

#################################################################################################################################

