## Lastly, we will do the mapping for a few files that have been stored on the cluster in a different folder but originate from the first sampling round. 
## We will now create new sample file list "Files_name7.list".
## This needs to be done inside the folder, 04.TrimmedData
ls *_1.trim* > Files_name7.list.tmp 
sed -E 's/(.*)_1\.trim\.pair\.fq\.gz/\1/' Files_name7.list.tmp > Files_name7.list
rm Files_name7.list.tmp
cp Files_name7.list /scratch/project_2009316/EuSamples/
## This lists the last samples used for training in a different prject

## "vim 5_mapping7.sh"

#################################################################################################################################
#!/bin/bash -l
#SBATCH -J AdrianaS
#SBATCH -o /scratch/project_2009316/EuSamples/05.BAM/logs/mapAdriana_%A_%a.out
#SBATCH -e /scratch/project_2009316/EuSamples/05.BAM/logs/mapAdriana_%A_%a.err
#SBATCH --account=project_2009316
#SBATCH -t 24:00:00
#SBATCH -p small
#SBATCH --array=1-2 ##3-6 change accordingly to samples
#SBATCH --ntasks=8
#SBATCH --mem=32G
#SBATCH --mail-type=START,FAIL,END

module load biokit
module load r-env

set -euo pipefail

cd /scratch/project_2009316/EuSamples

REFPATH=/scratch/project_2009316/rufaRefGenome       
TRIMPATH=/scratch/project_2009316/Adriana/X204SC23115958-Z01-F001_01/04.TrimmedData
TMPBAMPATH=/scratch/project_2009316/EuSamples/temp
BAMPATH=/scratch/project_2009316/EuSamples/05.BAM

## Files_name7.list
# Get R1 filename (without path) from array file
file=$(sed -n "${SLURM_ARRAY_TASK_ID}p" Files_name7.list)
shortfile=${file}

echo "###### STARTING file: $file (sample: $shortfile)"

# Define paths
tmpbam="${TMPBAMPATH}/${shortfile}.bam.tmp"
bam="${TMPBAMPATH}/${shortfile}.bam"
nodupl="${BAMPATH}/nodupl/${shortfile}_nodupl_RG.bam"
doneflag="${nodupl}.done"

# Skip completed samples
if [ -f "$doneflag" ] && samtools quickcheck "$nodupl"; then
    echo "###### SKIPPING $shortfile (already done)"
    exit 0
fi

###
### 1. Map, sort, index, and add Read groups (-R)
###
echo "###### MAPPING"

## Below, is the code for the new 2026 sequences and Files_name1.list
bwa mem -t8 "${REFPATH}/Frufa_PR_May2026.fa" \
    -R "@RG\tID:${shortfile}\tSM:${shortfile}\tPL:ILLUMINA\tLB:1\tPU:1" \
    "${TRIMPATH}/${file}_1.trim.pair.fq.gz" \    
    "${TRIMPATH}/${file}_2.trim.pair.fq.gz" \    
    | samtools sort -@8 -m512M -o "$tmpbam"

mv "$tmpbam" "$bam"
samtools index -@4 "$bam"

###
### 2. Insert size
###
echo "###### INSERT SIZE"

picard16 CollectInsertSizeMetrics \
    I="$bam" \
    O="${BAMPATH}/stats/${shortfile}_insert_size_metrics.txt" \
    H="${BAMPATH}/stats/${shortfile}_insert_size_hist.pdf"

###
### 3. Mark and remove duplicates 
###
echo "###### MARK DUPLICATES"

picard16 MarkDuplicates \
    I="$bam" \
    O="$nodupl" \
    M="${BAMPATH}/nodupl/stats/${shortfile}_dupl_metrics.txt" \
    REMOVE_DUPLICATES=true \
    TMP_DIR="$TMPBAMPATH"

###
### 4. Index + stats
###
echo "###### FINAL STATS"

samtools index -@4 "$nodupl"

samtools flagstat -@4 "$nodupl" > "${BAMPATH}/nodupl/stats/${shortfile}_nodupl_RG.flagstat"
samtools idxstats -@4 "$nodupl" > "${BAMPATH}/nodupl/stats/${shortfile}_nodupl_RG.idxstat"

# Check final BAM, mark completion, and clean up temp BAMs
if samtools quickcheck "$nodupl"; then
    # Mark completion
    touch "$doneflag"

    echo "###### CLEANING UP TEMP FILES FOR $shortfile"
    # Remove intermediate BAM and its index from the temp directory
    rm -f "$bam" "${bam}.bai" "$tmpbam" "${tmpbam}.bai"
else
    echo "###### WARNING: $nodupl failed samtools quickcheck; not removing temp BAMs"
fi

echo "###### DONE $shortfile"

#################################################################################################################################
