## Before, we run the SNP calling, we need to create a folder for the VCF file, "06.VCF" under /scratch/project_2009316/EuSamples/
cd /scratch/project_2009316/EuSamples
mkdir 06.VCF
## Further, we need to split the reference genome in equal data size regions to speed up the analysis fro freebayes. For more information, see the software information: https://docs.csc.fi/apps/freebayes/.

## We use the script "split_ref_by_bai_datasize.py" from the homepage. We copy-paste the script from https://github.com/freebayes/freebayes/blob/master/scripts/split_ref_by_bai_datasize.py into a python-script "split_ref_by_bai_datasize.py"
vim split_ref_by_bai_datasize.py

## After, copy-pasting the code, we change 'python3' into 'python' inside the script
## Note: I have already downloaded the script and pasted it here as a script. Also also the script has run, so no need to do this now. It is here for the sake of completeness.

## Further, we need an input list with all bam-files that should be used in splitting the reference genome and for the SNP calling.
cd /scratch/project_2009316/EuSamples/05.BAM/nodupl_clip
realpath *bam > all.bam.list
## NOTE: We have to exclude some files based on a low BAM coverage, namely:
## 121, A_272a, A_286e, A_307, A_335b, H_445_A, and RN417. In total, there are ####XX samples now.
## Remove them from the all.bam.list

## Now, for splitting the reference genome, we use the code below from the freebayes GitHub page, using sinteractive. 

##############################################
sinteractive --account project_2009316 --mem 2000
module load biopythontools

cd /scratch/project_2009316/EuSamples/06.VCF

python split_ref_by_bai_datasize.py \
-L /scratch/project_2009316/EuSamples/05.BAM/bam_final/all.bam.list \
-r /scratch/project_2009316/rufaRefGenome/Frufa_PR_May2026.fa.fai \
-s 5000000 > /scratch/project_2009316/rufaRefGenome/Frufa_PR_May2026_5e6_data_regions.fa.fai

#modify regions file so that Freebayes accepts it
cd /scratch/project_2009316/rufaRefGenome
awk 'BEGIN{OFS=""} {print $1,":",$2,"-",$3}' Frufa_PR_May2026_5e6_data_regions.fa.fai > Frufa_PR_May2026_v1_5e6_data_regions.txt

exit sinteractive

######################################################################################
## Below, we start the SNP calling. We use "screen" to run in on a screen for 72 h, see https://linuxize.com/post/how-to-use-linux-screen/?utm_content=cmp-true

## We  need to calculate the "--skip-coverage"
## --skip-coverage = total DP combined across all samples; assuming max 400x per sample per region, 400X per sample * 385 samples = 154,000
## However, with "--limit-coverage 100", the effective max total DP is actually 100 × 385 = 38,500, so --skip-coverage 57750 will almost never trigger in practice. So we could decrease it to 57750.
## This will be set in the freebayes code below.
## An additional note on "--skip-coverage": a value of, e.g., "200" means that each region will be skipped that has a higher sum count of 200. You can also reduced this value by using this idea for --skip-coverage: "Number of samples" x "mean coverage across all samples" x 2
## We also need a folder "raw" under the bam_final folder
## To detach from the "screen", use "Ctrl + A, then D". To list screen sessions, use "screen -ls". To reattach, use "screen -r"

###
### Full SNP calling
###

screen -S SNPcalling

module load freebayes # version used in 2023: v1.3.6

cd /scratch/project_2009316/EuSamples/06.VCF
REF=/scratch/project_2009316/refGenome
RES=/scratch/project_2009316/EuSamples/06.VCF
BAM=/scratch/project_2009316/EuSamples/05.BAM/bam_final

# screen have issues with code on many lines, so instead of backslashes use code on one line
# freebayes-puhti \
#  -time 72 \
#  -mem 64 \
#  -regions $REF/Formica_hybrid_v1_5e6_data_regions.txt \
#  -f $REF/Formica_hybrid_v1_wFhyb_Sapis.fa \
#  -L $BAM/all.bam.list \
#  -k --genotype-qualities --skip-coverage 15200 \
#  --limit-coverage 100 \ 
#  --use-best-n-alleles 3 \
#  -out $RES/raw/all_samples_raw.vcf


freebayes-puhti -time 72 -mem 64 -regions $REF/Formica_hybrid_v1_5e6_data_regions.txt -f $REF/Formica_hybrid_v1_wFhyb_Sapis.fa -L $BAM/all.bam.list -k --genotype-qualities --skip-coverage 15200 --limit-coverage 100 --use-best-n-alleles 3 -out $RES/raw/all_samples_raw.vcf


# max mean depth as per 'vcftools --depth' was 46x for sample 108-Flug. Later on all sites that have 2x per ind mean depth are anyway set as '.', which is why limiting to 100x with '--limit-coverage' is safe.
# -E N=-1 disable complex variants #NOT USED CURRENTLY -  does it mess up w snpgap and vcfallelicprimitives later on?
# --use-best-n-alleles 3 = reduce computational time to exclude multiple alternative alleles if present. Setting to 3 is safe since all but biallelic sites will be filtered out later on.


############# After the SNP calling, we do some sanity checks.
## For this, we use sinteractive and various tools:

sinteractive --account project_2009316 --mem 2000
cd /scratch/project_2009316/EuSamples/06.VCF/raw
module load biokit

## 1. Quick format sanity check (fastest)
## No output means that everything is okay
bcftools view all_samples_raw.vcf > /dev/null
## No output → VCF syntax is valid. If there are errors, this means there may be malformed lines, bad genotypes, or header issues

## 2. Inspect the header
bcftools view -h all_samples_raw.vcf
## fileformat=VCFv4.2 (or similar) exists
## source=freeBayes is present
## FORMAT fields like GT, DP, AD, RO, AO are defined
## Number of sample columns matches your expectations

## 3. Check for illegal or suspicious variants
bcftools norm -c w -f /scratch/project_2009316/refGenome/Formica_hybrid_v1_wFhyb_Sapis.fa all_samples_raw.vcf > /dev/null
## This will warn (not modify) about: REF allele mismatches, invalid indels, malformed alleles

## 4. Check chromosome naming
bcftools query -f '%CHROM\n' all_samples_raw.vcf | sort | uniq
## Look for chr1 vs 1 mixtures.

bcftools sort -c all_samples_raw.vcf
## If there is no output, then it is correclty sorted
## If there are errors, it needs needs sorting

## 5. Summary statistics
bcftools stats all_samples_raw.vcf > all_samples_raw.stats
## In the "all_samples_raw.stats" file, information on the number of SNPs, InDels, etc is stored.


