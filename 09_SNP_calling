module load biokit
cd /scratch/project_2009316/EuSamples/06.VCF/raw

# In the next step we "Sort" and "compress" the VCF file in one step.
bcftools sort -m 1G freebayes.vcf -Oz -o all_samples_raw.vcf.gz -T ./tmp_sort all_samples_raw.vcf.gz

## Compress
## bgzip all_samples_raw.vcf 
#samtools version 1.16.1, containing HTSlib 1.16
#This step is actually not needed as we already compressed it above when sorting!

# Index
tabix -p vcf all_samples_raw.vcf.gz
bcftools index -n all_samples_raw.vcf.gz

gunzip -c all_samples_raw.vcf.gz | grep -v "^#" | cut -f 1 | uniq -c > site_count_per_chromosome.tab

