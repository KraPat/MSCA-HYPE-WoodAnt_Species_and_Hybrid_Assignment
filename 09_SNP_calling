## The next checks take more time and shouldbe done in a batch job
## "vim 9_vcf_sanity.sh"

#################################################################################################################################

#!/bin/bash -l
#SBATCH -J vcf_sanity
#SBATCH -o /scratch/project_2009316/EuSamples/06.VCF/logs/VCFsanit_%A_%a.out
#SBATCH -e /scratch/project_2009316/EuSamples/06.VCF/logs/VCFsanit_%A_%a.err
#SBATCH --account=project_2009316
#SBATCH --time=24:00:00
#SBATCH -p small
#SBATCH --cpus-per-task=4
#SBATCH --mem=32G
#SBATCH --mail-type=START,FAIL,END

module load biokit

VCF=/scratch/project_2009316/EuSamples/06.VCF/raw/all_samples_raw.vcf
REF=/scratch/project_2009316/rufaRefGenome/Frufa_PR_May2026.fa

# 3. Check for illegal/suspicious variants
bcftools norm -c w -f "$REF" "$VCF" > /dev/null
## This will warn (not modify) about: REF allele mismatches, invalid indels, malformed alleles


# 4. Check for obvious duplication / weirdness
bcftools view -r <chrom_name> all_samples_raw.vcf | wc -l
## If one chromosome has an absurd number of lines, it might hint at:
## A per-read or per-allele VCF rather than per-site or something like a bug in the FreeBayes run or input.


# 5. Check coordinate ordering
bcftools sort -c "$VCF" > /dev/null
## Note: without redirection this will try to write the entire (sorted) VCF to stdout, which is huge.
## If you just want to check ordering, redirect to /dev/null as above.
## If there is no output, then it is correclty sorted
## If there are errors, it needs needs sorting


# 6. Summary statistics
bcftools stats "$VCF" > "${VCF%.vcf}.stats"
## In the "all_samples_raw.stats" file, information on the number of SNPs, InDels, etc is stored.



