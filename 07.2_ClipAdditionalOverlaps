## While most of the samples were clipped, some were not. We need to also clip these files.
## For this, we first create a new folder called "uncplippedSamples" and move the files into this folder:
mkdir uncplippedSamples
mv *_nodupl_wRG.bam

## Then, we create the input file list
ls *_nodupl_wRG.bam | sort -nk1,1 > input.listAdditFiles  #sort numeric, according to position 1,1

## Now we used the script to clip these overlap and index them directly.
## The script is called "7.1_ClipOverlapAddFiles.sh"
#################################################################################################################################
7.1_ClipOverlapAddFiles.sh

#!/bin/bash -l
BATCH -J clipOverlap
#SBATCH -o /scratch/project_2009316/EuSamples/05.BAM/logs/clipOverlap_%j.out
#SBATCH -e /scratch/project_2009316/EuSamples/05.BAM/logs/clipOverlap_%j.err
#SBATCH --account=project_2009316
#SBATCH -t 04:00:00
#SBATCH -p small
#SBATCH --array=1-2 ##3-20  change to number of samples
#SBATCH --ntasks 1
#SBATCH --mem-per-cpu=4GB
#SBATCH --mail-type=BEGIN,END,FAIL

# Load modules
module load biokit
export PATH="/projappl/project_2009316/myenv/bin:$PATH"

# Define directories
cd /scratch/project_2009316/EuSamples/05.BAM/bam_final/unclippedSamples
INPUTDIR=/scratch/project_2009316/EuSamples/05.BAM/bam_final/unclippedSamples
FINALDIR=/scratch/project_2009316/EuSamples/05.BAM/bam_final

# Get file & sample ID
file=$(sed -n "$SLURM_ARRAY_TASK_ID"p input.listAdditFiles)
sample=${file%_nodupl_wRG.bam}

echo "### Processing $file"

###
### Clip overlaps
###
# Reads are sorted by coordinates (see "samtools sort" command after mapping)
bam clipOverlap --in "$INPUTDIR/$file" --out "$FINALDIR/${sample}_nodupl_wRG_clip.bam" --stats --params

###
### Index
###
samtools index "$FINALDIR/${sample}_nodupl_wRG_clip.bam"

### END OF THE SCRIPT
#################################################################################################################################

